{
  "name": "@moser-inc/eslint-config",
  "version": "3.0.4",
  "homepage": "https://github.com/moser-inc/eslint-config#readme",
  "bugs": {
    "url": "https://github.com/moser-inc/eslint-config/issues"
  },
  "license": "ISC",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/moser-inc/eslint-config.git",
    "directory": "packages/core"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "exports": {
    ".": "./dist/index.mjs",
    "./package.json": "./package.json",
    "./flat": "./dist/index.mjs"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true,
    "registry": "https://registry.npmjs.org/"
  },
  "scripts": {
    "build": "tsdown",
    "prepack": "npm run build",
    "lint": "eslint -c eslint.config.ts && npm run lint:basic",
    "lint:basic": "eslint -c eslint.config.basic.ts",
    "lint:fix": "eslint --fix",
    "test:attw": "npx -y @arethetypeswrong/cli@latest --pack --profile esm-only",
    "test:publint": "npx -y publint@latest",
    "test:publish": "npm run test:attw && npm run test:publint",
    "type-check": "tsc --noEmit"
  },
  "dependencies": {
    "@eslint/js": "^9.39.3",
    "@typescript-eslint/eslint-plugin": "^8.56.1",
    "@typescript-eslint/parser": "^8.56.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-flat-config-utils": "^3.0.1",
    "eslint-import-resolver-alias": "^1.1.2",
    "eslint-import-resolver-typescript": "^4.4.4",
    "eslint-plugin-depend": "^1.5.0",
    "eslint-plugin-import-x": "^4.16.1",
    "eslint-plugin-prettier": "^5.5.5",
    "eslint-plugin-unicorn": "^63.0.0",
    "typescript-eslint": "^8.56.1"
  },
  "devDependencies": {
    "@types/node": "~24.10.15",
    "eslint": "^9.39.4",
    "eslint-typegen": "^2.3.1",
    "prettier": "^3.8.1",
    "tsdown": "^0.21.0",
    "typescript": "~5.9.3"
  },
  "peerDependencies": {
    "eslint": ">=9",
    "prettier": ">=3"
  }
}
