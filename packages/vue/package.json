{
  "name": "@moser-inc/eslint-config-vue",
  "version": "4.0.4",
  "type": "module",
  "exports": {
    ".": "./dist/index.mjs",
    "./package.json": "./package.json",
    "./flat": "./dist/index.mjs"
  },
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public",
    "provenance": true,
    "registry": "https://registry.npmjs.org/"
  },
  "scripts": {
    "build": "tsdown",
    "prepack": "npm run build",
    "lint": "eslint -c eslint.config.ts && npm run lint:basic",
    "lint:basic": "eslint -c eslint.config.basic.ts",
    "lint:fix": "eslint --fix",
    "test:attw": "npx -y @arethetypeswrong/cli@latest --pack --profile esm-only",
    "test:publint": "npx -y publint@latest",
    "test:publish": "npm run test:attw && npm run test:publint",
    "type-check": "tsc --noEmit"
  },
  "peerDependencies": {
    "eslint": ">= 6",
    "prettier": ">= 1",
    "vue": ">= 2.7"
  },
  "dependencies": {
    "@moser-inc/eslint-config": "3.0.3",
    "@vue/eslint-config-prettier": "^10.2.0",
    "@vue/eslint-config-typescript": "^14.7.0",
    "eslint-plugin-vue": "^10.8.0"
  },
  "devDependencies": {
    "eslint-typegen": "^2.3.1",
    "tsdown": "^0.21.0"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/moser-inc/eslint-config.git",
    "directory": "packages/vue"
  },
  "license": "ISC",
  "bugs": {
    "url": "https://github.com/moser-inc/eslint-config/issues"
  },
  "homepage": "https://github.com/moser-inc/eslint-config#readme"
}
