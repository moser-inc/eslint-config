{
  "name": "@moser-inc/eslint-config-react",
  "version": "5.1.4",
  "homepage": "https://github.com/moser-inc/eslint-config#readme",
  "bugs": {
    "url": "https://github.com/moser-inc/eslint-config/issues"
  },
  "license": "ISC",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/moser-inc/eslint-config.git",
    "directory": "packages/react"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "exports": {
    ".": "./dist/index.mjs",
    "./package.json": "./package.json",
    "./flat": "./dist/index.mjs"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true,
    "registry": "https://registry.npmjs.org/"
  },
  "scripts": {
    "build": "tsdown",
    "prepack": "npm run build",
    "lint": "eslint -c eslint.config.ts && npm run lint:basic",
    "lint:basic": "eslint -c eslint.config.basic.ts",
    "lint:fix": "eslint --fix",
    "test:attw": "npx -y @arethetypeswrong/cli@latest --pack --profile esm-only",
    "test:publint": "npx -y publint@latest",
    "test:publish": "npm run test:attw && npm run test:publint",
    "type-check": "tsc --noEmit"
  },
  "dependencies": {
    "@eslint-react/eslint-plugin": "^2.13.0",
    "@moser-inc/eslint-config": "3.0.4",
    "eslint-plugin-react-hooks": "^7.0.1"
  },
  "devDependencies": {
    "@types/node": "~24.10.15",
    "eslint": "^9.39.4",
    "eslint-typegen": "^2.3.1",
    "prettier": "^3.8.1",
    "tsdown": "^0.21.0",
    "typescript": "~5.9.3"
  },
  "peerDependencies": {
    "eslint": ">=9",
    "prettier": ">=9"
  }
}
