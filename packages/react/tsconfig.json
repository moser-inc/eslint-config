{
  "include": ["src", "*.config.*", "scripts/**/*"],
  "compilerOptions": {
    "noEmit": true,
    "composite": true,
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "strict": true,
    "skipDefaultLibCheck": true,
    "skipLibCheck": true,
    "erasableSyntaxOnly": true,
    "allowImportingTsExtensions": true
  }
}
